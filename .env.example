# Server configuration
PORT=3000

# MongoDB connection string
# IMPORTANT: For registration to work, MongoDB must be running as a replica set.
# Transactions in MongoDB only work on replica set / mongos, not on standalone mongod.
# If using local MongoDB, add ?replicaSet=rs0 to the URI
MONGODB_URI=mongodb://localhost:27017/testimonials_db?replicaSet=rs0

# JWT configuration
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRY=7d

# CORS allowed origins (comma-separated)
# REQUIRED in production - must be set explicitly
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001